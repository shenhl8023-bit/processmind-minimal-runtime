FROM node:20-alpine AS build

WORKDIR /app

COPY process-plan-agent-ui/package.json /app/package.json
COPY process-plan-agent-ui/package-lock.json /app/package-lock.json
RUN npm ci

COPY process-plan-agent-ui /app
COPY docs/配置模板/第三步工序问答共享模板.json /docs/配置模板/第三步工序问答共享模板.json
RUN npm run build

FROM nginx:1.27-alpine

COPY docker/nginx/default.conf /etc/nginx/conf.d/default.conf
COPY --from=build /app/dist /usr/share/nginx/html

EXPOSE 80

CMD ["nginx", "-g", "daemon off;"]
